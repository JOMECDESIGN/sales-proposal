{
  "mcpServers": {
    "lark": {
      "command": "npx",
      "args": [
        "-y",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a",
        "${FEISHU_APP_ID}",
        "-s",
        "${FEISHU_APP_SECRET}",
        "-d",
        "${FEISHU_DOMAIN:-https://open.feishu.cn}",
        "-t",
        "preset.doc.default,preset.base.default,preset.im.default"
      ]
    }
  }
}
