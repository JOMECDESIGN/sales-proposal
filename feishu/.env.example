# ── 飞书集成统一凭证(三层共用)─────────────────────────────
# 用法:复制为 feishu/.env 并填入真实值;.env 已被 .gitignore 忽略,不会入库。
#   cp feishu/.env.example feishu/.env
#
# 凭证来源:飞书开放平台 https://open.feishu.cn/app → 创建企业自建应用 → 凭证与基础信息
# 国际版 Lark:https://open.larksuite.com/app

# 应用凭证(三层都要)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 部署区域:cn = 飞书(中国);intl = Lark(国际版)
FEISHU_DOMAIN=cn

# ── 第③层 自建自动化 专用 ───────────────────────────────
# 默认通知群的 chat_id(机器人需先被拉进该群)。获取:python feishu/03-automation/list_chats.py
FEISHU_NOTIFY_CHAT_ID=oc_xxxxxxxxxxxxxxxx

# 销售管道多维表格(Bitable):app_token 来自表格 URL,table_id 来自具体数据表
FEISHU_PIPELINE_APP_TOKEN=bascnxxxxxxxxxxxxxxxx
FEISHU_PIPELINE_TABLE_ID=tblxxxxxxxxxxxxxx
