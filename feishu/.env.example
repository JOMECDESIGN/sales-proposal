# 飞书三层打通 · 共用凭证模板
# 用法:cp feishu/.env.example feishu/.env 并填入真实值。
# feishu/.env 已在 .gitignore,切勿提交;本仓库所有 *.example.* 均为脱敏模板。

# —— 应用凭证(三层共用)——
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 站点:https://open.feishu.cn(国内,默认) 或 https://open.larksuite.com(国际)
FEISHU_DOMAIN=https://open.feishu.cn

# —— ③ 自动化层:机器人卡片播报 ——
# 机器人需先被拉进目标群;chat_id 用  feishu-cli msg search-chats --query "<群名>"  获取
FEISHU_NOTIFY_CHAT_ID=oc_xxxxxxxxxxxxxxxx

# —— ③ 自动化层:销售管道多维表格(Bitable)——
FEISHU_PIPELINE_APP_TOKEN=bascnxxxxxxxxxxxxxxxxxxxx
FEISHU_PIPELINE_TABLE_ID=tblxxxxxxxxxxxxxx
